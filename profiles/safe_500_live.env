# Safe starter profile for live 500 USD deployment
BOT_MODE=live
BOT_CONFIG_PROFILE=safe_500_live

# Capital split
START_USDC=250
START_ETH=0
START_ETH_USD=250

# Conservative sizing
TRADE_SIZE_USD=25
MAX_TRADE_SIZE_USD=70
MAX_EXPOSURE_USD=170
MAX_INVENTORY_USD=170
MIN_ORDER_SIZE_USD=10

# Risk controls
MAX_DAILY_LOSS_USD=20
MAX_TRADES_PER_DAY=40
ACTIVITY_DAILY_AGGRESSIVE_TRADE_CAP=40
LOSS_PAUSE_MINUTES=30
MAX_CONSECUTIVE_LOSSES_BEFORE_PAUSE=6

# Drawdown ladder (3/5/8/10%)
CAPITAL_PRESERVATION_DRAWDOWN_PCT=3
RISK_BLOCK_DRAWDOWN_PCT=5
DRAWDOWN_PAUSE_PCT=8
KILL_SWITCH_USD=-50

# Execution realism
EXECUTION_MIN_EXPECTED_PROFIT_PCT=0.08
EXECUTION_MAKER_SLIPPAGE_BPS=6
EXECUTION_TAKER_SLIPPAGE_BPS=12
MAX_GAS_TO_PROFIT_RATIO=0.45
ENABLE_PRIVATE_TX=true

# Ops safety
TELEGRAM_ENABLED=true
TELEGRAM_DAILY_REPORT_ENABLED=true
RUNTIME_STATE_ENABLED=true
RUNTIME_STATE_PATH=logs/runtime_state_safe_500_live.json
