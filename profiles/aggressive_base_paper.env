# High-activity paper profile (template)
# ------------------------------------------------------------
# Hasznalat:
# 1) masold a projekt gyokerbe .env neven
# 2) toltsd ki a sajat RPC/Telegram/feed URL-eket
# 3) futtasd paper modban

# Core
BOT_MODE=paper
BOT_CONFIG_PROFILE=v8_activity
CHAIN=base
RPC_URL=
RPC_URLS=
RPC_TIMEOUT_SEC=10
RPC_MAX_RETRIES=3
RPC_RETRY_BACKOFF_SEC=2

# Wallet (paperben is maradhat ures)
WALLET_PRIVATE_KEY=
WALLET_ADDRESS=

# Trading / risk envelope
ACCOUNT_REFERENCE_MODE=dynamic
TRADE_SIZE_USD=30
MAX_TRADE_SIZE_USD=90
MAX_DAILY_LOSS_USD=35
MAX_EXPOSURE_USD=180
MIN_ORDER_SIZE_USD=10
MAX_INVENTORY_USD=180
MIN_TIME_BETWEEN_TRADES_MINUTES=0.20
MAX_TRADES_PER_DAY=120
ACTIVITY_DAILY_MIN_TRADE_TARGET=24
ACTIVITY_DAILY_GOOD_TRADE_TARGET=42
ACTIVITY_DAILY_AGGRESSIVE_TRADE_CAP=120
ACTIVITY_AUTO_LOOSEN_IF_LOW_ACTIVITY=true
INACTIVITY_FORCE_ENTRY_MINUTES=6
INACTIVITY_FORCE_ENTRY_THRESHOLD_BPS=3.0
INACTIVITY_FORCE_MIN_EDGE_BPS=-4.0
INACTIVITY_FORCE_SIZE_MULTIPLIER=0.80

# Trend + sentiment + onchain aligned boost
ACTIVITY_ALIGNMENT_BOOST_ENABLED=true
ACTIVITY_ALIGNMENT_MIN_EDGE_SCORE=68
ACTIVITY_ALIGNMENT_MIN_FEED_SCORE=0.08
ACTIVITY_ALIGNMENT_MAX_RISK_SCORE=0.62
ACTIVITY_ALIGNMENT_MIN_ONCHAIN_SCORE=-0.25
ACTIVITY_ALIGNMENT_BOOST_SIZE_MULTIPLIER=1.12
ACTIVITY_ALIGNMENT_BOOST_SPREAD_MULTIPLIER=0.94

# Signals (ajanlott: toltsd ki valos feedekkel)
SIGNAL_FETCH_ENABLED=true
NEWS_RSS_URLS=
MACRO_RSS_URLS=
ONCHAIN_RSS_URLS=

# Loop
LOOP_SECONDS=4
MAX_LOOPS=0

# Aggressive overrides (high trade frequency)
TRADE_COOLDOWN_MINUTES=1
MIN_TRADE_DISTANCE_PCT=0.15
EXECUTION_MIN_EXPECTED_PROFIT_PCT=0.10
MAX_TRADES_PER_DAY=100
ACTIVITY_DAILY_AGGRESSIVE_TRADE_CAP=150
CAPITAL_PRESERVATION_DRAWDOWN_PCT=12.0
SIDE_FLIP_COOLDOWN_CYCLES=2
INVENTORY_NORMAL_MIN=-0.22
INVENTORY_NORMAL_MAX=0.22
INVENTORY_UPTREND_MAX=0.40
INVENTORY_DOWNTREND_MIN=-0.40
INTELLIGENCE_SIGNAL_ALIGNMENT_THRESHOLD=0.35

# External filters temporarily disabled
ENABLE_NEWS_FILTER=false
ENABLE_SENTIMENT_FILTER=false
ENABLE_MACRO_FILTER=false

# Explicitly keep paper trading enabled
PAPER_TRADING=true

# Aggressive Base Paper Profile - célja: magas trade frequency

# Base chain defaults
BASE_RPC_URL=https://mainnet.base.org
# Alternatív RPC-ként később private RPC-t is használhatunk
CHAIN_ID=8453

WETH_ADDRESS=0x4200000000000000000000000000000000000006
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# DEX beállítások (egyelőre általános)
DEX_TYPE=aerodrome          # vagy uniswap_v3
SLIPPAGE_TOLERANCE=0.005    # 0.5%

PAPER_TRADING=true

# ============== BASE CHAIN + UNISWAP V3 CONFIG ==============
BASE_RPC_URL=https://mainnet.base.org
CHAIN_ID=8453

WETH_ADDRESS=0x4200000000000000000000000000000000000006
USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# DEX beállítások
DEX_TYPE=uniswap_v3
UNISWAP_V3_FACTORY=0x1F98431c8aD98523631AE4a59f267346ea31F984
UNISWAP_V3_QUOTER=0x3d4e44Eb1374240CE5F1B871ab261CD16335B76a
UNISWAP_V3_ROUTER=0x2626664c2603336E57B271c5C0b26F421741e481   # SwapRouter02 Base-en
UNISWAP_V3_NFT_MANAGER=0x03a520b32C04BF3bEEf7BEb72E919cf822Ed34f1

# Uniswap V3 specifikus
SLIPPAGE_TOLERANCE=0.005          # 0.5%
MAX_GAS_PRICE_GWEI=10
DEADLINE_SECONDS=600

# Paper trading
PAPER_TRADING=true

# Megjegyzés
# Jelenleg paper módban futunk, Uniswap V3 concentrated liquidity támogatást készítünk elő

# ============================================================================
# ÚJONNAN HOZZÁADOTT BASE + UNISWAP V3 VÁLTOZÓK MAGYARÁZATA
# ============================================================================
# BASE_RPC_URL: A Base mainnet RPC endpoint, ezen keresztül kommunikál a bot a lánccal.
# CHAIN_ID: A Base hálózat azonosítója (8453), tranzakciók/signing helyes célhálózatához.
# WETH_ADDRESS: A Base-en használt canonical WETH token szerződéscíme.
# USDC_ADDRESS: A Base-en használt USDC token szerződéscíme.
# DEX_TYPE: Kiválasztja a használt DEX implementációt (itt: uniswap_v3).
# UNISWAP_V3_FACTORY: Uniswap V3 Factory cím, pool-ok és fee tier-ek feloldásához.
# UNISWAP_V3_QUOTER: Quoter cím, várható swap kimenetek és árjegyzés becsléséhez.
# UNISWAP_V3_ROUTER: SwapRouter02 cím, tényleges swap tranzakciók végrehajtásához Base-en.
# UNISWAP_V3_NFT_MANAGER: NonfungiblePositionManager cím, V3 LP pozíciók kezeléséhez (NFT alapú).
# SLIPPAGE_TOLERANCE: Maximális megengedett slippage arány (0.005 = 0.5%).
# MAX_GAS_PRICE_GWEI: Felső gázár-limit (gwei), költségkontroll és túl drága blokkok szűréséhez.
# DEADLINE_SECONDS: Tranzakció érvényességi időablak másodpercben (lejárat swapokra/route-okra).
# PAPER_TRADING: Paper mód kapcsoló; true esetén éles végrehajtás helyett szimulált kereskedés fut.
# ============================================================================
